---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Gracias por solicitar información"
  description="Recibimos tu solicitud. Un agente licenciado se comunicará contigo"
>
  <main class="thank-you">
    <section class="container thank-you__content">
      <p class="eyebrow">Solicitud recibida</p>
      <h1>Gracias por tu interés</h1>
      <p>
        Recibimos tu información correctamente. Un agente licenciado se comunicará contigo para ayudarte con el próximo paso
      </p>
      <a class="button button--primary" href="/">Volver al inicio</a>
    </section>
  </main>
</BaseLayout>
